generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("student")
  reviews   Review[]
  createdAt DateTime @default(now())
}

model Establishment {
  id        String   @id @default(uuid())
  name      String
  reviews   Review[]
}

model Review {
  id              String        @id @default(uuid())
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  establishmentId String
  foodScore       Int
  serviceScore    Int
  priceScore      Int
  comment         String
  createdAt       DateTime      @default(now())

  @@unique([userId, establishmentId])
}

model ModelMetrics {
  id           String   @id @default(uuid())
  version      String
  accuracy     Float
  f1Score      Float
  datasetSize  Int
  executedAt   DateTime @default(now())
}
